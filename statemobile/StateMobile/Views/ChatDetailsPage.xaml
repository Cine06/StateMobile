        <Frame Grid.Row="2" Padding="10,8" BackgroundColor="White">
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                
                <!-- Attachment & Scan Buttons -->
                <HorizontalStackLayout Spacing="5">
                    <ImageButton Source="plus_icon.png" 
                                 Command="{Binding PickAttachmentCommand}"
                                 HeightRequest="25" WidthRequest="25" />
                    <ImageButton Source="mic_vm.png" 
                                 Command="{Binding ScanDocumentCommand}"
                                 HeightRequest="25" WidthRequest="25" />
                </HorizontalStackLayout>

                <Editor Grid.Column="1"
                        Placeholder="Type a message..."
                        Text="{Binding NewMessageText}"
                        AutoSize="TextChanges"
                        MaximumHeightRequest="100" />

                <ImageButton Grid.Column="2"
                             Source="send_arrow.png"
                             Command="{Binding SendMessageCommand}"
                             HeightRequest="32" WidthRequest="32" />
            </Grid>
        </Frame>
