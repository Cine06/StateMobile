<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2001/xaml"
             xmlns:vm="clr-namespace:StateMobile.ViewModel"
             xmlns:models="clr-namespace:StateMobile.Models"
             xmlns:selectors="clr-namespace:StateMobile.Selectors"
             x:Class="StateMobile.Views.ChatDetailsPage"
             Title="{Binding SelectedRoom.RoomName}"
             BackgroundColor="{StaticResource Secondary}">

    <ContentPage.Resources>
        <selectors:ChatMessageTemplateSelector x:Key="MessageSelector" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto">
        
        <!-- Chat Messages List -->
        <!-- ItemsUpdatingScrollMode="KeepLastItemInView" is critical for mobile chat -->
        <CollectionView x:Name="MessagesList"
                        Grid.Row="0"
                        ItemsSource="{Binding Messages}"
                        ItemTemplate="{StaticResource MessageSelector}"
                        ItemsUpdatingScrollMode="KeepLastItemInView"
                        VerticalScrollBarVisibility="Never"
                        Margin="10,0">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
            </CollectionView.ItemsLayout>
        </CollectionView>

        <!-- Mobile Input Area -->
        <Frame Grid.Row="1" 
               Padding="10,5" 
               Margin="0"
               CornerRadius="0"
               HasShadow="False"
               BorderColor="{StaticResource Gray200}"
               BackgroundColor="White">
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                
                <Editor x:Name="MessageEntry"
                        Placeholder="Type a message..."
                        Text="{Binding NewMessageText}"
                        AutoSize="TextChanges"
                        MaximumHeightRequest="120"
                        VerticalOptions="Center"
                        Keyboard="Chat"
                        BackgroundColor="Transparent" />

                <ImageButton Grid.Column="1"
                             Source="send_arrow.png"
                             Command="{Binding SendMessageCommand}"
                             HeightRequest="35"
                             WidthRequest="35"
                             VerticalOptions="End"
                             Margin="0,0,5,5">
                    <ImageButton.Triggers>
                        <DataTrigger TargetType="ImageButton"
                                     Binding="{Binding NewMessageText.Length}"
                                     Value="0">
                            <Setter Property="Opacity" Value="0.5" />
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                    </ImageButton.Triggers>
                </ImageButton>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>