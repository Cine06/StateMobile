<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:StateMobile.Views"
             x:Class="StateMobile.Views.AccountSettingsPage"
             Title="Account Settings"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#0F0F1E}">

    <Grid RowDefinitions="Auto, *">
        <!-- Modern Header -->
        <Border Grid.Row="0" Margin="0,0,0,10" BackgroundColor="{AppThemeBinding Light=White, Dark=#151525}" StrokeThickness="0" HeightRequest="60">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05" />
            </Border.Shadow>
            <Grid ColumnDefinitions="50, *, 50" Padding="10,0">
                <ImageButton Source="back_icon.png" 
                             WidthRequest="24" 
                             HeightRequest="24" 
                             BackgroundColor="Transparent"
                             Clicked="OnBackButtonClicked"
                             HorizontalOptions="Center" 
                             VerticalOptions="Center"/>
                <Label Grid.Column="1" 
                       Text="Account Settings" 
                       FontSize="18" 
                       FontAttributes="Bold" 
                       VerticalOptions="Center" 
                       TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}"
                       HorizontalOptions="Center"/>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="25">

                <!-- Profile Section -->
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Grid HeightRequest="100" WidthRequest="100">
                        <Border HeightRequest="100" 
                                WidthRequest="100" 
                                StrokeShape="RoundRectangle 50" 
                                StrokeThickness="0" 
                                BackgroundColor="#498789">
                            <Grid>
                                <!-- Initial Label (Visible if no photo) -->
                                <Label Text="{Binding Initial}" 
                                       FontSize="40" 
                                       TextColor="White" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center" 
                                       FontAttributes="Bold"
                                       IsVisible="{Binding UserPhoto, Converter={StaticResource NullToTrueConverter}}"/>
                                
                                <!-- Profile Image (Visible if photo exists) -->
                                <Image Source="{Binding UserPhoto}" 
                                       Aspect="AspectFill"
                                       HeightRequest="100"
                                       WidthRequest="100"
                                       IsVisible="{Binding UserPhoto, Converter={StaticResource NullToFalseConverter}}">
                                    <Image.Clip>
                                        <EllipseGeometry Center="50,50" RadiusX="50" RadiusY="50" />
                                    </Image.Clip>
                                </Image>
                            </Grid>
                        </Border>

                        <!-- Edit Icon Overlay -->
                        <Border HeightRequest="32" 
                                WidthRequest="32" 
                                StrokeShape="RoundRectangle 16" 
                                VerticalOptions="End" 
                                HorizontalOptions="End" 
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#151525}" 
                                StrokeThickness="1" 
                                Stroke="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A3E}">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="3" Opacity="0.1" />
                            </Border.Shadow>
                            <Label Text="📷" 
                                   FontSize="16" 
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center"/>
                        </Border>

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnModifyProfilePictureClicked"/>
                        </Grid.GestureRecognizers>
                    </Grid>

                    <Label Text="{Binding UserName}" 
                           FontSize="22" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center" 
                           TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}"/>
                    <Label Text="{Binding DepartmentName}" 
                           FontSize="14" 
                           TextColor="{AppThemeBinding Light=Gray, Dark=#A0AEC0}" 
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Settings Groups -->
                <VerticalStackLayout Spacing="15">

                    <Label Text="General" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#498789, Dark=#A4C2C2}" Margin="5,0"/>

                    <Border StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light=White, Dark=#151525}" StrokeThickness="0" Padding="5">
                        <VerticalStackLayout>
                            <Grid ColumnDefinitions="40, *, Auto" Padding="15" ColumnSpacing="10">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPersonalInformationTapped"/>
                                </Grid.GestureRecognizers>
                                <Label Text="👤" FontSize="20" VerticalOptions="Center"/>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="Personal Information" FontAttributes="Bold" FontSize="14" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                                    <Label Text="Name, Department, Employee ID" FontSize="11" TextColor="{AppThemeBinding Light=Gray, Dark=#A0AEC0}"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="›" FontSize="24" TextColor="{AppThemeBinding Light=#BDC3C7, Dark=#666666}" VerticalOptions="Center"/>
                            </Grid>

                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A3E}" Margin="40,0,15,0"/>

                            <Grid ColumnDefinitions="40, *, Auto" Padding="15" ColumnSpacing="10">
                                <Label Text="🔔" FontSize="20" VerticalOptions="Center"/>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="Notifications" FontAttributes="Bold" FontSize="14" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                                    <Label Text="Push notifications and alerts" FontSize="11" TextColor="{AppThemeBinding Light=Gray, Dark=#A0AEC0}"/>
                                </VerticalStackLayout>
                                <Switch Grid.Column="2" IsToggled="True" OnColor="#498789" ThumbColor="White" Scale="0.8"/>
                            </Grid>

                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A3E}" Margin="40,0,15,0"/>

                            <Grid ColumnDefinitions="40, *, Auto" Padding="15" ColumnSpacing="10">
                                <Label Text="🌙" FontSize="20" VerticalOptions="Center"/>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="Dark Mode" FontAttributes="Bold" FontSize="14" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                                    <Label Text="Toggle application dark theme" FontSize="11" TextColor="{AppThemeBinding Light=Gray, Dark=#A0AEC0}"/>
                                </VerticalStackLayout>
                                <Switch Grid.Column="2" 
                                        IsToggled="{Binding IsDarkModeEnabled}" 
                                        Toggled="OnDarkModeToggled"
                                        OnColor="#498789" 
                                        ThumbColor="White" 
                                        Scale="0.8"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="Security" 
                           FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light=#498789, Dark=#A4C2C2}" 
                           Margin="5,0" 
                           Padding="0,10,0,0"
                           IsVisible="{Binding IsBiometricSupported}"/>

                    <Border StrokeShape="RoundRectangle 12" 
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#151525}" 
                            StrokeThickness="0" 
                            Padding="5"
                            IsVisible="{Binding IsBiometricSupported}">
                        <VerticalStackLayout>
                            <Grid ColumnDefinitions="40, *, Auto" Padding="15" ColumnSpacing="10">
                                <Label Text="🔒" FontSize="20" VerticalOptions="Center"/>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="Screen Lock" FontAttributes="Bold" FontSize="14" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                                    <Label Text="Biometric or PIN" FontSize="11" TextColor="{AppThemeBinding Light=Gray, Dark=#A0AEC0}"/>
                                </VerticalStackLayout>
                                <Switch Grid.Column="2" 
                                        IsToggled="{Binding IsScreenLockEnabled}" 
                                        Toggled="OnScreenLockToggled"
                                        OnColor="#498789" 
                                        ThumbColor="White" 
                                        Scale="0.8"/>
                            </Grid>

                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A3E}" Margin="40,0,15,0"/>

                            <Grid ColumnDefinitions="40, *, Auto" Padding="15" ColumnSpacing="10">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnChangePasswordTapped"/>
                                </Grid.GestureRecognizers>
                                <Label Text="🔑" FontSize="20" VerticalOptions="Center"/>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="Change Password" FontAttributes="Bold" FontSize="14" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                                    <Label Text="Update your security credentials" FontSize="11" TextColor="{AppThemeBinding Light=Gray, Dark=#A0AEC0}"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="›" FontSize="24" TextColor="{AppThemeBinding Light=#BDC3C7, Dark=#666666}" VerticalOptions="Center"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- About / Logout Footer -->
                    <Label Text="About" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#498789, Dark=#A4C2C2}" Margin="5,0" Padding="0,10,0,0"/>
                    <Border StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light=White, Dark=#151525}" StrokeThickness="0" Padding="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="App Version" FontSize="14" VerticalOptions="Center" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                            <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                <Label Text="{Binding AppVersion}" FontSize="14" TextColor="{AppThemeBinding Light=Gray, Dark=#A0AEC0}"/>
                                <Border BackgroundColor="#E74C3C" 
                                        StrokeShape="RoundRectangle 4" 
                                        Padding="5,2" 
                                        IsVisible="{Binding IsUpdateAvailable}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnUpdateClicked"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="{Binding LatestVersion, StringFormat='Update to {0}'}" 
                                           FontSize="10" 
                                           TextColor="White" 
                                           FontAttributes="Bold"/>
                                </Border>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>

                    <Button Text="Sign Out" 
                            BackgroundColor="Transparent" 
                            TextColor="#E74C3C" 
                            FontAttributes="Bold" 
                            Command="{Binding LogoutCommand}"
                            Margin="0,20,0,40"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</views:BasePage>
