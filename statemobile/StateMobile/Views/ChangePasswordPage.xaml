<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:StateMobile.Views"
             x:Class="StateMobile.Views.ChangePasswordPage"
             Title="Change Password"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#121212}">

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,10" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" StrokeThickness="0" HeightRequest="60">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05" />
            </Border.Shadow>
            <Grid ColumnDefinitions="50, *, 50" Padding="10,0">
                <ImageButton Source="back_icon.png" 
                             WidthRequest="24" 
                             HeightRequest="24" 
                             BackgroundColor="Transparent" 
                             Clicked="OnBackButtonClicked"
                             HorizontalOptions="Center" 
                             VerticalOptions="Center"/>
                <Label Grid.Column="1" 
                       Text="Change Password" 
                       FontSize="18" 
                       FontAttributes="Bold" 
                       VerticalOptions="Center" 
                       TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}"
                       HorizontalOptions="Center"/>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="25" Spacing="20">

                <Label Text="Your new password must be at least 8 characters long and should contain a mix of letters, numbers, and symbols." 
                       FontSize="13" 
                       TextColor="{AppThemeBinding Light=Gray, Dark=#B0B0B0}" 
                       HorizontalTextAlignment="Center"/>

                <Border StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" StrokeThickness="0" Padding="20">
                    <VerticalStackLayout Spacing="15">

                        <!-- Current Password -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Current Password" FontSize="12" TextColor="#498789" FontAttributes="Bold"/>
                            <Entry Placeholder="Enter current password" IsPassword="True" Text="{Binding CurrentPassword}" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F0, Dark=#333333}"/>

                        <!-- New Password -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="New Password" FontSize="12" TextColor="#498789" FontAttributes="Bold"/>
                            <Entry Placeholder="Enter new password" IsPassword="True" Text="{Binding NewPassword}" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F0, Dark=#333333}"/>

                        <!-- Confirm New Password -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Confirm New Password" FontSize="12" TextColor="#498789" FontAttributes="Bold"/>
                            <Entry Placeholder="Confirm new password" IsPassword="True" Text="{Binding ConfirmPassword}" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <Button Text="Update Password" 
                        BackgroundColor="#498789" 
                        TextColor="White" 
                        HeightRequest="55" 
                        CornerRadius="12" 
                        FontAttributes="Bold"
                        Clicked="OnUpdatePasswordClicked"
                        Margin="0,10,0,0"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</views:BasePage>
