<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StateMobile.Views.LoginPage"
             xmlns:viewmodel="clr-namespace:StateMobile.ViewModel"
             x:DataType="viewmodel:LoginPageViewModel"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Content>
        <Grid IgnoreSafeArea="True" 
              RowDefinitions="{OnPlatform Default='*,Auto', WinUI='*'}"
              ColumnDefinitions="{OnPlatform Default='*', WinUI='1.1*, *'}">
            <!-- Main Background (Gradient left, white right for Windows) -->
            <Grid BackgroundColor="{AppThemeBinding Light=#D9E6E6, Dark=#0F1A1A}" Grid.RowSpan="2" Grid.ColumnSpan="2">
               <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#B3498789" Offset="0.1" />
                        <GradientStop Color="#4DFFFFFF" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>
            </Grid>

            <!-- Right Side White Background for Windows -->
            <Border Grid.Column="1" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" IsVisible="{OnPlatform WinUI=True, Default=False}" 
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="40,0,0,40"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#BF000000" Offset="-5,0" Radius="30" Opacity="0.1"/>
                </Border.Shadow>
            </Border>

            <VerticalStackLayout Grid.Row="0" Grid.Column="0"
                                 VerticalOptions="Center"
                                 Spacing="12"
                                 Margin="{OnPlatform WinUI='0', Default='0,40,0,20'}"
                                 Padding="40,0">
                <Image Source="state_logo_only.png"
                       HeightRequest="{OnPlatform WinUI=180, Default=110}"
                       WidthRequest="{OnPlatform WinUI=180, Default=110}"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"/>

                <Label Text="STATE GROUP OF COMPANIES"
                       TextColor="#498789"
                       HorizontalTextAlignment="Center"
                       FontAttributes="Bold"
                       FontSize="{OnPlatform WinUI=24, Default=18}"
                       CharacterSpacing="1.2"
                       LineHeight="1.2"
                       Margin="0,5,0,0"
                       Shadow="{Shadow Brush=#40000000, Offset='0,2', Radius=4, Opacity=0.25}"/>
            </VerticalStackLayout>

            <Border Grid.Row="{OnPlatform WinUI=0, Default=1}"
                    Grid.Column="{OnPlatform WinUI=1, Default=0}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                    Padding="{OnPlatform WinUI='50,25', Default='30,25'}"
                    StrokeThickness="0"
                    VerticalOptions="{OnPlatform WinUI=Center, Default=End}"
                    HorizontalOptions="{OnPlatform WinUI=Center, Default=Fill}"
                    WidthRequest="{OnPlatform WinUI=500, Default=-1}"
                    Margin="{OnPlatform WinUI='0,0,50,0', Default='0'}">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{OnPlatform WinUI=40, Default='35,35,0,0'}"/>
                </Border.StrokeShape>

                <ScrollView Orientation="Vertical" 
                            VerticalScrollBarVisibility="Never" 
                            MaximumHeightRequest="600">
                    <VerticalStackLayout Spacing="18">

                        <Label Text="Log In"
                               FontSize="{OnPlatform WinUI=28, Default=16}"
                               FontAttributes="Bold"
                               TextColor="#498789"
                               HorizontalOptions="Center"
                               Margin="0,0,0,5"/>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="User ID" FontSize="12" TextColor="#498789" FontAttributes="Bold" Margin="4,0"/>
                            <Border Stroke="{AppThemeBinding Light=#D9E6E6, Dark=#333333}" StrokeThickness="1" HeightRequest="55" StrokeShape="RoundRectangle 28" Padding="15,0" BackgroundColor="{AppThemeBinding Light=#F7FBFB, Dark=#2A2A2A}">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label FontSize="18" VerticalOptions="Center" Margin="0,0,10,0" TextColor="#498789"/>
                                    <Entry Grid.Column="1" Text="{Binding Username}" Placeholder="Enter your email" PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#808080}" TextColor="{AppThemeBinding Light=Black, Dark=White}" FontSize="14" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="3">
                            <Label Text="Password" FontSize="12" TextColor="#498789" FontAttributes="Bold" Margin="4,0"/>
                            <Border Stroke="{AppThemeBinding Light=#D9E6E6, Dark=#333333}" StrokeThickness="1" HeightRequest="55" StrokeShape="RoundRectangle 28" Padding="15,0" BackgroundColor="{AppThemeBinding Light=#F7FBFB, Dark=#2A2A2A}">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Label FontSize="18" VerticalOptions="Center" Margin="0,0,10,0" TextColor="#498789"/>
                                    <Entry Grid.Column="1" 
                                           Text="{Binding Password}" 
                                           IsPassword="{Binding IsPasswordHidden}" 
                                           Placeholder="Enter your password" 
                                           PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#808080}" TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                           FontSize="14" 
                                           VerticalOptions="Center"/>

                                    <ImageButton Grid.Column="2" 
                                                 Source="{Binding IsPasswordHidden, Converter={StaticResource PasswordIconConverter}}"
                                                 Command="{Binding TogglePasswordCommand}" 
                                                 HeightRequest="30" 
                                                 WidthRequest="30"
                                                 Scale="0.8" 
                                                 Padding="0"
                                                 Aspect="AspectFit"
                                                 VerticalOptions="Center"
                                                 HorizontalOptions="Center"
                                                 BackgroundColor="Transparent" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <HorizontalStackLayout Margin="0,-10,0,0">
                            <CheckBox Color="#498789" IsChecked="{Binding RememberMe}" Scale="0.8"/>
                            <Label Text="Remember me" VerticalOptions="Center" TextColor="{AppThemeBinding Light=#4F6F70, Dark=#B0B0B0}" FontSize="13"/>
                        </HorizontalStackLayout>

                        <Grid HeightRequest="55">
                            <Button Text="Login"
                                    Command="{Binding LoginCommand}"
                                    BackgroundColor="#498789"
                                    TextColor="White"
                                    CornerRadius="28"
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Text" Value="" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>

                            <ActivityIndicator IsRunning="{Binding IsBusy}" 
                                               IsVisible="{Binding IsBusy}" 
                                               Color="White" 
                                               HorizontalOptions="Center" 
                                               VerticalOptions="Center"
                                               HeightRequest="24"
                                               WidthRequest="24" />
                        </Grid>

                        <VerticalStackLayout IsVisible="{Binding IsScreenLockAvailable}" Spacing="10" Margin="0,5,0,10">
                            <Label Text="— OR —" TextColor="#9BBFC0" FontSize="11" HorizontalOptions="Center"/>
                            <Button Text="🔓 Use Screen Lock"
                                    Command="{Binding ScreenLockLoginCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="#498789"
                                    BorderColor="#498789"
                                    BorderWidth="1"
                                    HeightRequest="45"
                                    CornerRadius="22"
                                    FontSize="13" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>
            </Border>

            <!-- Simplified Busy Overlay for Mobile when needed -->
            <ContentView Grid.RowSpan="2" Grid.ColumnSpan="2" 
                         BackgroundColor="#80FFFFFF" 
                         IsVisible="{Binding IsBusy}">
                <ActivityIndicator IsRunning="True" Color="#498789" HorizontalOptions="Center" VerticalOptions="Center" Scale="1.5"/>
            </ContentView>
        </Grid>
    </ContentPage.Content>
</ContentPage>