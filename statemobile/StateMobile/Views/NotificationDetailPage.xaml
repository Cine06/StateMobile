<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="StateMobile.Views.NotificationDetailPage"
             Title="Notification Details"
             BackgroundColor="{AppThemeBinding Light=#F4F6F8, Dark=#0F0F1E}">

    <ScrollView>
        <VerticalStackLayout Padding="16,24,16,40" Spacing="24">
            
            <!-- Main Info Card -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#2A2A40}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#171729}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{AppThemeBinding Light=#1A000000, Dark=Transparent}" 
                            Offset="0,4"
                            Radius="12"
                            Opacity="1" />
                </Border.Shadow>
                
                <VerticalStackLayout Padding="20" Spacing="16">
                    <!-- Title & Status Header -->
                    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="8">
                        <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                               Text="{Binding Title}" 
                               FontSize="22" 
                               FontAttributes="Bold"
                               LineHeight="1.2"
                               TextColor="{AppThemeBinding Light=#020617, Dark=White}" />
                               
                        <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6" VerticalOptions="Center">
                            <Label Text="&#x1F551;" 
                                   FontSize="12" 
                                   TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}"
                                   VerticalOptions="Center" />
                            <Label Text="{Binding TimeAgo}" 
                                   FontSize="13" 
                                   TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" 
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Read Status Indicator -->
                        <Border Grid.Row="1" Grid.Column="1" 
                                StrokeShape="RoundRectangle 12"
                                Padding="10,4"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#1E1E38}"
                                IsVisible="{Binding IsUnread}"
                                VerticalOptions="Center">
                            <HorizontalStackLayout Spacing="6">
                                <Ellipse WidthRequest="6" HeightRequest="6" Fill="#6366F1" VerticalOptions="Center"/>
                                <Label Text="New" FontSize="11" TextColor="#6366F1" FontAttributes="Bold" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                        
                        <HorizontalStackLayout Grid.Row="1" Grid.Column="1" 
                                               IsVisible="{Binding IsUnread, Converter={toolkit:InvertedBoolConverter}}" 
                                               Spacing="4" 
                                               VerticalOptions="Center">
                            <Label Text="&#x2713;" FontSize="11" TextColor="{AppThemeBinding Light=#10B981, Dark=#10B981}" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Label Text="{Binding ReadStatusText}" 
                                   FontSize="12" 
                                   TextColor="{AppThemeBinding Light=#10B981, Dark=#10B981}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Grid>
                    
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E2E8F0, Dark=#2A2A40}" Margin="0,4" />

                    <!-- Metadata Grid -->
                    <Grid ColumnDefinitions="100, *" RowDefinitions="Auto, Auto, Auto" RowSpacing="12">
                        
                        <Label Grid.Row="0" Grid.Column="0" Text="Module" FontSize="13" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" VerticalOptions="Center" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding ModuleName}" FontSize="14" TextColor="{AppThemeBinding Light=#0F172A, Dark=#E2E8F0}" VerticalOptions="Center" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Reference" FontSize="13" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" VerticalOptions="Center" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Code}" FontSize="14" TextColor="{AppThemeBinding Light=#0F172A, Dark=#E2E8F0}" VerticalOptions="Center" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Request By" FontSize="13" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" VerticalOptions="Center" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding RequestBy}" FontSize="14" FontAttributes="Bold" TextColor="#3B82F6" VerticalOptions="Center" />
                        
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Message Card -->
            <VerticalStackLayout Spacing="12">
                <Label Text="MESSAGE" 
                       FontSize="13" 
                       FontAttributes="Bold" 
                       Margin="4,0,0,0"
                       CharacterSpacing="1"
                       TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" />
                       
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#171729}" 
                       StrokeThickness="1"
                       Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#2A2A40}"
                       Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Light=#0A000000, Dark=Transparent}" 
                                Offset="0,2"
                                Radius="8"
                                Opacity="1" />
                    </Border.Shadow>
                    
                    <Label Text="{Binding Message}" 
                           FontSize="15" 
                           LineHeight="1.6"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F1F5F9}" 
                           LineBreakMode="WordWrap" />
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
