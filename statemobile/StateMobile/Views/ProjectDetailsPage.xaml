<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:StateMobile.Views"
             xmlns:models="clr-namespace:StateMobile.Models"
             x:Class="StateMobile.Views.ProjectDetailsPage"
             ControlTemplate="{StaticResource MainPageTemplate}"
             NavigationPage.HasNavigationBar="False"
             Title="Project Details"
             BackgroundColor="{AppThemeBinding Light=#F5F6F7, Dark=#0F0F0F}">

    <Grid RowDefinitions="Auto, Auto, *">
        <!-- Offline Mode Banner -->
        <Border Grid.Row="0" 
                x:Name="OfflineBanner"
                IsVisible="{Binding IsOfflineMode}"
                BackgroundColor="#FFF3CD" 
                StrokeThickness="0"
                Padding="12,8"
                Margin="0">
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="&#x26A0;" FontSize="14" VerticalOptions="Center" />
                <Label Text="Offline Mode - Diary entries will be saved locally" 
                       FontSize="12" 
                       FontAttributes="Bold"
                       TextColor="#856404" 
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>
        
        <!-- 🏆 Professional Top Section (Clean Header + Quick Stats) -->
        <VerticalStackLayout Grid.Row="1" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Spacing="0">
            <!-- Unified Header & Project Context -->
            <BoxView HeightRequest="2" Color="#3D6D6E" />
            <Grid ColumnDefinitions="Auto, *" Padding="20,10" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                <Button Grid.Column="0" 
                        Text="❮" 
                        FontAttributes="Bold"
                        FontSize="14"
                         TextColor="{AppThemeBinding Light=#1A2D3E, Dark=White}" 
                        BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#333333}" 
                        HeightRequest="44" 
                        WidthRequest="44" 
                        CornerRadius="22" 
                        Clicked="OnBackClicked" 
                        VerticalOptions="Center" />

                <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center" Spacing="2">
                    <Label Text="{Binding CurrentProject.Particulars}" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light=#000000, Dark=White}" 
                           MaxLines="1" 
                           LineBreakMode="TailTruncation" />
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="{Binding CurrentProject.ProjName}" 
                               FontSize="13" 
                               TextColor="{AppThemeBinding Light=#000000, Dark=#CCCCCC}" />
                        <Label Text="•" TextColor="#CBD5E1" VerticalOptions="Center" />
                        <Label Text="{Binding CurrentProject.CtrlNo, StringFormat='ID: {0}'}" 
                               FontSize="11" 
                               TextColor="#3D6D6E" 
                               FontAttributes="Bold" 
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>

            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#333333}" />
            
            <!-- Slim Combined Header: Title + Filter + Action -->
            <Grid Padding="20,6" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#151515}" RowDefinitions="Auto, Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                        <Label Text="Project Update Entries" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=White}" />
                        <Label Text="View manage all your project entries here" FontSize="9" TextColor="{AppThemeBinding Light=#000000, Dark=#CCCCCC}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="+" 
                            BackgroundColor="#3D6D6E" 
                            TextColor="White" 
                            CornerRadius="6" 
                            Padding="6,0" 
                            HeightRequest="10" 
                            FontSize="25" 
                            FontAttributes="Bold" 
                            Clicked="OnNewEntryClicked" />
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto, *, Auto" ColumnSpacing="2" HeightRequest="28" Margin="0,4,0,0">
                    <Button Grid.Column="0" Text="⇠" FontSize="20" TextColor="#94A3B8" BackgroundColor="Transparent" Clicked="OnFilterPreviousClicked" Padding="0" HeightRequest="25" />
                    
                    <!-- From Date Container -->
                    <Grid Grid.Column="1">
                        <DatePicker x:Name="FilterStartDate" 
                                   Opacity="0.01" 
                                   VerticalOptions="FillAndExpand" 
                                   HorizontalOptions="FillAndExpand" 
                                   DateSelected="OnFilterDateChanged" />
                        <Label Text="{Binding FilteredFromText}" 
                               TextColor="#3D6D6E" 
                               FontSize="11" 
                               FontAttributes="Bold" 
                               VerticalOptions="Center" 
                               HorizontalOptions="Center" 
                               InputTransparent="True" />
                    </Grid>

                    <Label Grid.Column="2" Text="—" TextColor="#CBD5E1" VerticalOptions="Center" HorizontalOptions="Center" />

                    <!-- To Date Container -->
                    <Grid Grid.Column="3">
                        <DatePicker x:Name="FilterEndDate" 
                                   Opacity="0.01" 
                                   VerticalOptions="FillAndExpand" 
                                   HorizontalOptions="FillAndExpand" 
                                   DateSelected="OnFilterDateChanged" />
                        <Label Text="{Binding FilteredToText}" 
                               TextColor="#3D6D6E" 
                               FontSize="11" 
                               FontAttributes="Bold" 
                               VerticalOptions="Center" 
                               HorizontalOptions="Center" 
                               InputTransparent="True" />
                    </Grid>

                    <Button Grid.Column="4" Text="⇢" FontSize="20" TextColor="#94A3B8" BackgroundColor="Transparent" Clicked="OnFilterNextClicked" Padding="0" HeightRequest="25" />
                </Grid>
            </Grid>
            
            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F1F5F9, Dark=#333333}" />
        </VerticalStackLayout>

        <!-- Diary Entries List -->
        <RefreshView Grid.Row="2" IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshCommand}" Margin="15,10">
            <CollectionView x:Name="DiaryCollectionView" 
                            ItemsSource="{Binding DiaryEntries}"
                            EmptyView="No diary entries found. Click '+ New Entry' to record one.">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ProjectDiaryModel">
                        <!-- 🟦 Unified Professional Diary Card (Mobile-First Layout) -->
                        <VerticalStackLayout Spacing="15" Margin="10,10,10,20">
                            
                            <!-- MAIN TEXT CARD -->
                            <Border Padding="15" 
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#444444}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#252525}">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.04" />
                                </Border.Shadow>
                                
                                <Grid>
                                    <Grid RowDefinitions="Auto, *, Auto" RowSpacing="15">
                                        <!-- Header: Date and Options -->
                                        <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto, *, Auto">
                                            <Label Grid.Column="0" Text="{Binding DiaryDateFormatted}" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=White}" VerticalOptions="Center" />
                                            
                                            <!-- Pending Sync Badge (only visible for offline entries) -->
                                            <Border Grid.Column="1" 
                                                    IsVisible="{Binding IsOffline}" 
                                                    BackgroundColor="#FFF3CD" 
                                                    StrokeThickness="0" 
                                                    StrokeShape="RoundRectangle 10"
                                                    Padding="8,3"
                                                    Margin="8,0,0,0"
                                                    VerticalOptions="Center">
                                                <Label Text="Pending Sync" FontSize="10" FontAttributes="Bold" TextColor="#856404" />
                                            </Border>
                                            
                                            <Border Grid.Column="3" StrokeThickness="0" BackgroundColor="Transparent" Padding="5">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnDiaryEntryOptionsClicked" CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Path Data="M12,16A2,2 0 0,1 14,18A2,2 0 0,1 12,20A2,2 0 0,1 10,18A2,2 0 0,1 12,16M12,10A2,2 0 0,1 14,12A2,2 0 0,1 12,14A2,2 0 0,1 10,12A2,2 0 0,1 12,10M12,4A2,2 0 0,1 14,6A2,2 0 0,1 12,8A2,2 0 0,1 10,6A2,2 0 0,1 12,4Z"
                                                      Fill="#475569" Aspect="Uniform" HeightRequest="16" WidthRequest="16" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                        </Grid>

                                        <!-- Details List -->
                                        <Grid Grid.Row="1" ColumnDefinitions="125, *" RowDefinitions="Auto, Auto, Auto" RowSpacing="8" VerticalOptions="Start">
                                            <Label Grid.Row="0" Grid.Column="0" Text="Weather:" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=White}" />
                                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding StatusText}" FontSize="13" TextColor="{AppThemeBinding Light=#000000, Dark=#E0E0E0}" />

                                            <Label Grid.Row="1" Grid.Column="0" Text="Weather Remarks:" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=White}" />
                                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding DiaryWeatherRemarks}" FontSize="13" TextColor="{AppThemeBinding Light=#000000, Dark=#E0E0E0}" />

                                            <Label Grid.Row="2" Grid.Column="0" Text="Activities:" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=White}" VerticalOptions="Start" />
                                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding DiaryActivities}" FontSize="13" TextColor="{AppThemeBinding Light=#000000, Dark=#E0E0E0}" LineBreakMode="WordWrap" />
                                        </Grid>

                                        <!-- Footer Line and Name -->
                                        <VerticalStackLayout Grid.Row="2" Spacing="10" VerticalOptions="End">
                                            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#333333}" />
                                            <Label Text="{Binding AuditUser, StringFormat='Posted By: {0}'}" FontSize="11" TextColor="{AppThemeBinding Light=#000000, Dark=#ACACAC}" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <!-- OVERLAY DROPDOWN MENU -->
                                    <Border IsVisible="{Binding IsMenuVisible}" HorizontalOptions="End" VerticalOptions="Start" Margin="0,30,0,0" WidthRequest="110" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 4">
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.1" />
                                        </Border.Shadow>
                                        <VerticalStackLayout Spacing="0">
                                            <Grid Padding="12,10" BackgroundColor="Transparent">
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnEditEntryMenuClicked" CommandParameter="{Binding .}" />
                                                </Grid.GestureRecognizers>
                                                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                                    <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" Fill="#475569" Aspect="Uniform" HeightRequest="14" WidthRequest="14" />
                                                    <Label Text="Edit" TextColor="#475569" FontSize="13" VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </Grid>
                                            <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" />
                                            <Grid Padding="12,10" BackgroundColor="Transparent">
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnDeleteEntryMenuClicked" CommandParameter="{Binding .}" />
                                                </Grid.GestureRecognizers>
                                                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                                    <Path Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z" Fill="#EF4444" Aspect="Uniform" HeightRequest="14" WidthRequest="14" />
                                                    <Label Text="Delete" TextColor="#EF4444" FontSize="13" VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- PHOTO CARDS CAROUSEL -->
                            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Always" Margin="0,0,0,10">
                                <StackLayout BindableLayout.ItemsSource="{Binding Photos}" Orientation="Horizontal" Spacing="15" Padding="5">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:ProjectDiaryPhotoModel">
                                            <Border WidthRequest="320" 
                                                    StrokeShape="RoundRectangle 8"
                                                    StrokeThickness="1"
                                                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#444444}"
                                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#252525}"
                                                    Padding="0">
                                                <Border.Shadow>
                                                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.04" />
                                                </Border.Shadow>

                                                <Grid RowDefinitions="220, Auto">
                                                    <!-- Image -->
                                                    <Grid Grid.Row="0">
                                                        <Image Source="{Binding PhotoUrl}" Aspect="AspectFill">
                                                            <Image.GestureRecognizers>
                                                                <TapGestureRecognizer Tapped="OnPhotoTapped" CommandParameter="{Binding PhotoUrl}" />
                                                            </Image.GestureRecognizers>
                                                        </Image>
                                                    </Grid>

                                                    <!-- Photo Details Footer -->
                                                    <Grid Grid.Row="1" Padding="15">
                                                        <VerticalStackLayout Spacing="5" VerticalOptions="Center">
                                                            <HorizontalStackLayout Spacing="5">
                                                                <Label Text="Description:" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=White}" />
                                                                <Label Text="{Binding PhotoDescription}" FontSize="13" TextColor="{AppThemeBinding Light=#000000, Dark=#E0E0E0}" MaxLines="1" LineBreakMode="TailTruncation" />
                                                            </HorizontalStackLayout>
                                                            <Label Text="{Binding AuditUser, StringFormat='Posted By: {0}'}" FontSize="13" TextColor="{AppThemeBinding Light=#000000, Dark=#ACACAC}" />
                                                            <Label Text="{Binding DiaryDateFormatted, StringFormat='Posted Date: {0}'}" FontSize="13" TextColor="{AppThemeBinding Light=#000000, Dark=#ACACAC}" />
                                                        </VerticalStackLayout>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </StackLayout>
                            </ScrollView>
                        </VerticalStackLayout>
                    </DataTemplate>

                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Loading Skeleton Overlay -->
        <VerticalStackLayout Grid.Row="2"
                             IsVisible="{Binding IsBusy}"
                             BackgroundColor="{AppThemeBinding Light=#F5F6F7, Dark=#0F0F0F}"
                             ZIndex="999"
                             Spacing="1">
            <ContentView ControlTemplate="{StaticResource ProjectEntrySkeletonTemplate}" />
            <ContentView ControlTemplate="{StaticResource ProjectEntrySkeletonTemplate}" />
        </VerticalStackLayout>

        <!-- 🏦 Advanced Add/Edit Entry Modal (Overlay) -->
        <ContentView x:Name="AddEntryModal" Grid.RowSpan="3" BackgroundColor="#A0000000" IsVisible="False">
            <Border VerticalOptions="Center" 
                    HorizontalOptions="Center" 
                    MaximumWidthRequest="500" 
                    MaximumHeightRequest="800" 
                    StrokeShape="RoundRectangle 24" 
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" 
                    Padding="0"
                    Margin="20">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="30" Opacity="0.3" />
                </Border.Shadow>

                <Grid RowDefinitions="Auto, *, Auto">
                    <!-- Modal Header -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#151515}" Padding="20,15">
                        <Label Text="{Binding ModalTitle}" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=White}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="✕" FontAttributes="Bold" TextColor="#94A3B8" FontSize="18" BackgroundColor="Transparent" Clicked="OnCancelClicked" />
                    </Grid>

                    <!-- Modal Body -->
                    <ScrollView Grid.Row="1" Padding="20">
                        <VerticalStackLayout Spacing="20">
                            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="Entry Date" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=White}" />
                                    <DatePicker x:Name="EntryDatePicker" TextColor="{AppThemeBinding Light=#000000, Dark=White}" BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#2A2A2A}" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="Weather Status" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=White}" />
                                    <Picker x:Name="WeatherPicker" TextColor="{AppThemeBinding Light=#000000, Dark=White}" BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#2A2A2A}">
                                        <Picker.Items>
                                            <x:String>Not Workable</x:String>
                                            <x:String>Workable</x:String>
                                        </Picker.Items>
                                    </Picker>
                                </VerticalStackLayout>
                            </Grid>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Weather Remarks" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=#A0AEC0}" />
                                <Entry x:Name="RemarksEditor" Placeholder="e.g. Sunny morning" BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#2A2A2A}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Daily Activities" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=#A0AEC0}" />
                                <Editor x:Name="ActivitiesEditor" Placeholder="What was done today?" HeightRequest="120" BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#2A2A2A}" />
                            </VerticalStackLayout>

                            <!-- Modern Image Documentation Section -->
                            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#333333}" Margin="0,10" />
                            <Label Text="File Upload" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=White}" />

                            <Grid ColumnDefinitions="*, *" ColumnSpacing="15" HeightRequest="110">
                                <Border Grid.Column="0" StrokeDashArray="6,6" Stroke="{AppThemeBinding Light=#CBD5E1, Dark=#555555}" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A1A1A}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnCapturePhotoClicked" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="4">
                                        <Path Data="M12,17.5C14.33,17.5 16.31,16.04 17.11,14H6.89C7.69,16.04 9.67,17.5 12,17.5M12,9C9.79,9 8,10.79 8,13C8,15.21 9.79,17 12,17C14.21,17 16,15.21 16,13C16,10.79 14.21,9 12,9M20,4H16.83L15,2H9L7.17,4H4C2.9,4 2,4.9 2,6V18C2,19.1 2.9,20 4,20H20C21.1,20 22,19.1 22,18V6C22,4.9 21.1,4 20,4Z" 
                                              Fill="#498789" Aspect="Uniform" HeightRequest="32" WidthRequest="32" HorizontalOptions="Center" Margin="0,0,0,4" />
                                        <Label Text="Take Photo" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#334155, Dark=White}" HorizontalOptions="Center" />
                                        <Label Text="Direct to camera" FontSize="11" TextColor="#94A3B8" HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Column="1" x:Name="UploadArea" StrokeDashArray="6,6" Stroke="{AppThemeBinding Light=#CBD5E1, Dark=#555555}" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A1A1A}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSelectPhotoClicked" />
                                        <DropGestureRecognizer AllowDrop="True" Drop="OnUploadAreaDropped" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="4">
                                        <Path Data="M21,19V5C21,3.9 20.1,3 19,3H5C3.9,3 3,3.9 3,5V19C3,20.1 3.9,21 5,21H19C20.1,21 21,20.1 21,19M8.5,13.5L11,16.51L14.5,12L19,18H5L8.5,13.5Z" 
                                              Fill="#94A3B8" Aspect="Uniform" HeightRequest="32" WidthRequest="32" HorizontalOptions="Center" Margin="0,0,0,4" />
                                        <Label Text="Browse Gallery" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#334155, Dark=White}" HorizontalOptions="Center" />
                                        <Label Text="Pick from files" FontSize="11" TextColor="#94A3B8" HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectedPhotos}" Spacing="15" Margin="0,15,0,0">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="views:PhotoEntryModel">
                                        <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="#E2E8F0" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#252525}" Padding="0">
                                            <Border.Shadow>
                                                <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.04" />
                                            </Border.Shadow>

                                            <Grid RowDefinitions="200, Auto">
                                                <!-- Image -->
                                                <Grid Grid.Row="0">
                                                    <Image Source="{Binding PhotoSource}" Aspect="AspectFill" />
                                                    
                                                    <!-- Direct Delete Button -->
                                                    <Border HorizontalOptions="End" VerticalOptions="Start" Margin="10" BackgroundColor="#E6FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 18" Padding="5" WidthRequest="36" HeightRequest="36">
                                                        <Border.Shadow>
                                                            <Shadow Brush="Black" Opacity="0.1" Offset="0,2" Radius="4" />
                                                        </Border.Shadow>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Tapped="OnDeleteDraftPhotoDirectClicked" CommandParameter="{Binding .}" />
                                                        </Border.GestureRecognizers>
                                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                              Fill="#EF4444" Aspect="Uniform" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                                    </Border>
                                                </Grid>

                                                <!-- Footer -->
                                                <Grid Grid.Row="1" Padding="15">
                                                    <Grid ColumnDefinitions="Auto, *">
                                                        <Label Grid.Column="0" Text="Description:" FontSize="13" FontAttributes="Bold" TextColor="#475569" VerticalOptions="Center" Margin="0,0,10,0" />
                                                        <Editor Grid.Column="1" Text="{Binding Description, Mode=TwoWay}" Placeholder="Write description..." AutoSize="TextChanges" FontSize="13" TextColor="#64748B" BackgroundColor="Transparent" />
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>

                    <!-- Modal Actions -->
                    <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="15" Padding="20" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#151515}">
                        <Button Grid.Column="0" Text="Discard" Clicked="OnCancelClicked" BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#333333}" TextColor="{AppThemeBinding Light=#475569, Dark=#CCCCCC}" CornerRadius="10" HeightRequest="45" />
                        <Button Grid.Column="1" Text="Save Record" Clicked="OnSaveEntryClicked" BackgroundColor="#3D6D6E" TextColor="White" FontAttributes="Bold" CornerRadius="10" HeightRequest="45" />
                    </Grid>
                </Grid>
            </Border>
        </ContentView>

        <!-- FULL-SCREEN IMAGE VIEWER OVERLAY -->
        <ContentView x:Name="ImageModal" Grid.RowSpan="3" IsVisible="False" BackgroundColor="#E6000000" Padding="10">
            <ContentView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseImageModalClicked" />
            </ContentView.GestureRecognizers>
            <Grid>
                <Image x:Name="FullScaleImage" Aspect="AspectFit" Margin="0,40,0,0" />
                <Border HorizontalOptions="End" VerticalOptions="Start" Margin="10,20,10,0" WidthRequest="40" HeightRequest="40" BackgroundColor="#80000000" StrokeShape="RoundRectangle 20" StrokeThickness="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCloseImageModalClicked" />
                    </Border.GestureRecognizers>
                    <Label Text="✕" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </Grid>
        </ContentView>
    </Grid>
</views:BasePage>
