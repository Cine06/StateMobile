<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StateMobile.Views.CameraScanPage"
             Title="Scan Document"
             BackgroundColor="Black">

    <Grid RowDefinitions="*, Auto, Auto">
        <!-- Camera Preview Area -->
        <CameraUpdateView x:Name="cameraView" Grid.Row="0" />

        <!-- Captured Pages Thumbnails -->
        <ScrollView Grid.Row="1" Orientation="Horizontal" HeightRequest="100" BackgroundColor="#33000000">
            <HorizontalStackLayout x:Name="ThumbnailList" Spacing="10" Padding="10" />
        </ScrollView>

        <!-- Controls -->
        <Grid Grid.Row="2" ColumnDefinitions="*, *, *" Padding="20" BackgroundColor="#1A1A1A">
            <Button Text="Cancel" Clicked="OnCancelClicked" Grid.Column="0" BackgroundColor="Transparent" TextColor="White"/>
            
            <Ellipse WidthRequest="70" HeightRequest="70" Fill="White" Stroke="Gray" StrokeThickness="4" Grid.Column="1" HorizontalOptions="Center">
                <Ellipse.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCaptureClicked" />
                </Ellipse.GestureRecognizers>
            </Ellipse>

            <Button x:Name="DoneButton" Text="Done (0)" Clicked="OnDoneClicked" Grid.Column="2" 
                    BackgroundColor="#498789" TextColor="White" CornerRadius="20" IsEnabled="False"/>
        </Grid>
    </Grid>
</ContentPage>