<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StateMobile.Views.PdfPreviewPage"
             Title="Review & Sign"
             BackgroundColor="#E5E5E5">

    <Grid RowDefinitions="*, Auto">
        <CollectionView Grid.Row="0" ItemsSource="{Binding Document.Pages}" ItemsLayout="VerticalList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="20" Spacing="10">
                        <Label Text="{Binding PageNumber, StringFormat='Page {0}'}" HorizontalOptions="Center" FontAttributes="Bold"/>
                        
                        <Frame Padding="0" HasShadow="True" WidthRequest="350" HeightRequest="495" BackgroundColor="White" HorizontalOptions="Center">
                            <Grid>
                                <Image Source="{Binding ImagePath}" Aspect="AspectFit" />
                                
                                <!-- Signature Overlay -->
                                <Image Source="{Binding Signature.SignatureData, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                                       IsVisible="{Binding Signature, Converter={StaticResource IsNotNullConverter}}"
                                       TranslationX="{Binding Signature.X}"
                                       TranslationY="{Binding Signature.Y}"
                                       WidthRequest="120"
                                       HeightRequest="60"
                                       HorizontalOptions="Start" 
                                       VerticalOptions="Start" />
                            </Grid>
                        </Frame>

                        <Button Text="Sign this Page" 
                                Clicked="OnAddSignatureClicked"
                                CommandParameter="{Binding .}"
                                BackgroundColor="#498789"
                                CornerRadius="20"
                                WidthRequest="150"
                                HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="1" Text="Generate PDF" 
                Clicked="OnGeneratePdfClicked"
                BackgroundColor="#054b45" 
                TextColor="White" 
                HeightRequest="60"
                CornerRadius="0"/>
    </Grid>
</ContentPage>