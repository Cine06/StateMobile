<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StateMobile.Views.PdfPreviewPage"
             Title="Document Preview">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="20" Padding="20">
                <BindableLayout.ItemsSource="{Binding Document.Pages}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="0" HasShadow="True" BorderColor="Gray">
                                <Grid>
                                    <Image Source="{Binding ImagePath}" Aspect="AspectFit" />
                                    <!-- Signature Overlay Logic -->
                                    <Image Source="{Binding Signature.SignatureData, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                                           IsVisible="{Binding Signature, Converter={StaticResource IsNotNullConverter}}"
                                           TranslationX="{Binding Signature.X}"
                                           TranslationY="{Binding Signature.Y}"
                                           WidthRequest="{Binding Signature.Width}"
                                           HeightRequest="{Binding Signature.Height}"
                                           HorizontalOptions="Start" VerticalOptions="Start" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </BindableLayout>
            </VerticalStackLayout>
        </ScrollView>

        <HorizontalStackLayout Grid.Row="1" Spacing="10" Padding="10" HorizontalOptions="Center">
            <Button Text="Add Signature to Page" Command="{Binding AddSignatureCommand}" />
            <Button Text="Save PDF" Command="{Binding SavePdfCommand}" />
        </HorizontalStackLayout>
    </Grid>
</ContentPage>