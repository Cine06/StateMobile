<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StateMobile.Views.PdfPreviewPage"
             Title="Document Preview"
             BackgroundColor="#F5F7F8">

    <Grid RowDefinitions="*, Auto">
        
        <!-- Long Scrollable Preview (Req 3) -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="20">
                <BindableLayout.ItemsSource="{Binding ScannedDoc.Pages}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="0" HasShadow="True" BorderColor="#E0E0E0">
                                <Grid>
                                    <Image Source="{Binding ImagePath}" Aspect="AspectFit" />
                                    
                                    <!-- Signature Overlay (Req 2, 10) -->
                                    <Image Source="{Binding SignatureData, Converter={StaticResource ByteArrayToImageSource}}"
                                           IsVisible="{Binding SignatureData, Converter={StaticResource IsNotNullConverter}}"
                                           TranslationX="{Binding SignatureX}"
                                           TranslationY="{Binding SignatureY}"
                                           Scale="{Binding SignatureScale}"
                                           HorizontalOptions="Start" VerticalOptions="Start" />
                                    
                                    <Button Text="Add Signature" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AddSignatureCommand}"
                                            CommandParameter="{Binding .}"
                                            VerticalOptions="End" HorizontalOptions="Center" Margin="10"
                                            BackgroundColor="#498789" TextColor="White" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </BindableLayout.ItemsSource>
            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="1" Text="Generate Professional PDF" 
                Command="{Binding GeneratePdfCommand}"
                Margin="20" HeightRequest="50" CornerRadius="25"
                BackgroundColor="#054b45" TextColor="White" />
    </Grid>
</ContentPage>