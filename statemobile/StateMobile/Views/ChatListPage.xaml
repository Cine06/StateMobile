<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StateMobile.Views.ChatListPage"
             Title="Messages"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto, *">
        <!-- Search Bar -->
        <Frame Grid.Row="0" Margin="15,10" Padding="12,0" CornerRadius="20" HasShadow="False" BackgroundColor="#F1F3F4" BorderColor="Transparent">
            <Grid ColumnDefinitions="Auto, *">
                <Image Source="search_icon_gray.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center" Margin="5,0,10,0"/>
                <Entry Grid.Column="1" Placeholder="Search conversations..." FontSize="14" VerticalOptions="Center" TextColor="#333333"/>
            </Grid>
        </Frame>

        <!-- Conversations List -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding ChatRooms}" SelectionMode="Single" SelectionChanged="OnConversationSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="15,10" ColumnDefinitions="60, *, Auto" RowDefinitions="Auto, Auto">
                        <!-- Avatar -->
                        <Frame Grid.Column="0" Grid.RowSpan="2" WidthRequest="50" HeightRequest="50" CornerRadius="25" Padding="0" IsClippedToBounds="True" HasShadow="False" BorderColor="#E0E0E0">
                            <Image Source="{Binding RoomImage}" Aspect="AspectFill" />
                        </Frame>

                        <!-- Name & Time -->
                        <Label Grid.Column="1" Text="{Binding RoomName}" FontAttributes="Bold" FontSize="16" TextColor="#333333" VerticalOptions="End" Margin="10,0,0,0"/>
                        <Label Grid.Column="2" Text="{Binding LastMessageTime}" FontSize="12" TextColor="#999999" VerticalOptions="End"/>

                        <!-- Last Message & Unread Badge -->
                        <Label Grid.Column="1" Grid.Row="1" Text="{Binding LastMessage}" FontSize="14" TextColor="#666666" MaxLines="1" LineBreakMode="TailTruncation" Margin="10,2,0,0"/>
                        <Frame Grid.Column="2" Grid.Row="1" IsVisible="{Binding UnreadCount, Converter={StaticResource GreaterThanZeroConverter}}" 
                               BackgroundColor="#498789" CornerRadius="10" Padding="6,2" HasShadow="False" HorizontalOptions="End" VerticalOptions="Start" Margin="0,5,0,0">
                            <Label Text="{Binding UnreadCount}" TextColor="White" FontSize="10" FontAttributes="Bold"/>
                        </Frame>
                        
                        <BoxView Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" HeightRequest="1" BackgroundColor="#F0F0F0" VerticalOptions="End" Margin="10,10,0,-10"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- New Chat FAB -->
        <Button Grid.Row="1" Text="+" FontSize="24" BackgroundColor="#054b45" TextColor="White" 
                WidthRequest="56" HeightRequest="56" CornerRadius="28" 
                HorizontalOptions="End" VerticalOptions="End" Margin="20" Shadow="{Shadow Brush=Black, Offset='0,4', Radius=10, Opacity=0.2}"/>
    </Grid>
</ContentPage>