<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:StateMobile.Views"
             x:Class="StateMobile.Views.ProfilePage"
             Title="Personal Information"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#0F0F1E}">

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,10" BackgroundColor="{AppThemeBinding Light=White, Dark=#151525}" StrokeThickness="0" HeightRequest="60">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05" />
            </Border.Shadow>
            <Grid ColumnDefinitions="50, *, 50" Padding="10,0">
                <ImageButton Source="back_icon.png" 
                             WidthRequest="24" 
                             HeightRequest="24" 
                             BackgroundColor="Transparent" 
                             Clicked="OnBackButtonClicked"
                             HorizontalOptions="Center" 
                             VerticalOptions="Center"/>
                <Label Grid.Column="1" 
                       Text="Personal Information" 
                       FontSize="18" 
                       FontAttributes="Bold" 
                       VerticalOptions="Center" 
                       TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}"
                       HorizontalOptions="Center"/>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">
                
                <!-- Profile Avatar -->
                <Border StrokeShape="RoundRectangle 60" 
                        HeightRequest="120" WidthRequest="120"
                        HorizontalOptions="Center" 
                        BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#2A2A3E}"
                        StrokeThickness="0"
                        Margin="0,0,0,10">
                    <Image Source="{Binding UserPhoto}"
                           Aspect="AspectFill"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill">
                        <!-- Placeholder could be added here if needed -->
                    </Image>
                </Border>

                <!-- Info Cards -->
                <Border StrokeShape="RoundRectangle 15" BackgroundColor="{AppThemeBinding Light=White, Dark=#151525}" StrokeThickness="0" Padding="20">
                    <VerticalStackLayout Spacing="20">
                        
                        <!-- Full Name -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="FULL NAME" FontSize="12" TextColor="{AppThemeBinding Light=#498789, Dark=#A4C2C2}" FontAttributes="Bold"/>
                            <Label Text="{Binding UserName}" FontSize="16" TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}"/>
                        </VerticalStackLayout>
                        
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A3E}"/>

                        <!-- Nickname -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="NICKNAME" FontSize="12" TextColor="{AppThemeBinding Light=#498789, Dark=#A4C2C2}" FontAttributes="Bold"/>
                            <Border IsVisible="{Binding IsEditing}" Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2A2A3E}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0" BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#1A1A2E}">
                                <Entry Text="{Binding Nickname}" FontSize="15" TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}" BackgroundColor="Transparent"/>
                            </Border>
                            <Label IsVisible="{Binding IsNotEditing}" Text="{Binding Nickname}" FontSize="16" TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A3E}"/>

                        <!-- Employee ID (AISNo) -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="EMPLOYEE ID / AIS NO" FontSize="12" TextColor="{AppThemeBinding Light=#498789, Dark=#A4C2C2}" FontAttributes="Bold"/>
                            <Label Text="{Binding UserAISNo}" FontSize="16" TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A3E}"/>

                        <!-- Mobile -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="MOBILE NO." FontSize="12" TextColor="{AppThemeBinding Light=#498789, Dark=#A4C2C2}" FontAttributes="Bold"/>
                            <Border IsVisible="{Binding IsEditing}" Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2A2A3E}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0" BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#1A1A2E}">
                                <Entry Text="{Binding Mobile}" Keyboard="Telephone" FontSize="15" TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}" BackgroundColor="Transparent"/>
                            </Border>
                            <Label IsVisible="{Binding IsNotEditing}" Text="{Binding Mobile}" FontSize="16" TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A3E}"/>

                        <!-- Department -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="DEPARTMENT" FontSize="12" TextColor="{AppThemeBinding Light=#498789, Dark=#A4C2C2}" FontAttributes="Bold"/>
                            <Label Text="{Binding DepartmentName}" FontSize="16" TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A3E}"/>

                        <!-- Role/Status (Static placeholder for now) -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="ACCOUNT STATUS" FontSize="12" TextColor="{AppThemeBinding Light=#498789, Dark=#A4C2C2}" FontAttributes="Bold"/>
                            <HorizontalStackLayout Spacing="8">
                                <Ellipse WidthRequest="10" HeightRequest="10" Fill="#2ECC71"/>
                                <Label Text="Active" FontSize="16" TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <Grid IsVisible="{Binding IsEditing}" ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                    <Button Grid.Column="0" Text="Cancel" 
                            Clicked="OnCancelClicked"
                            BackgroundColor="Transparent" 
                            TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}" 
                            BorderColor="{AppThemeBinding Light=#2C3E50, Dark=White}"
                            BorderWidth="1"
                            FontAttributes="Bold" 
                            CornerRadius="25" 
                            HeightRequest="50" />

                    <Button Grid.Column="1" Text="Save Changes" 
                            Clicked="OnSaveClicked"
                            BackgroundColor="#498789" 
                            TextColor="White" 
                            FontAttributes="Bold" 
                            CornerRadius="25" 
                            HeightRequest="50" />
                </Grid>

                <Button IsVisible="{Binding IsNotEditing}" Text="Edit Profile" 
                        Clicked="OnEditClicked"
                        BackgroundColor="#498789" 
                        TextColor="White" 
                        FontAttributes="Bold" 
                        CornerRadius="25" 
                        HeightRequest="50" 
                        Margin="0,10,0,0" />

                <Label Text="Name and Department are imported from system records. To update them, please contact your IT Administrator." 
                       FontSize="12" 
                       TextColor="{AppThemeBinding Light=Gray, Dark=#A0AEC0}" 
                       HorizontalTextAlignment="Center" 
                       Margin="20,0"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ✅ Loading Skeleton Overlay -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsBusy}"
                BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#0F0F1E}"
                StrokeThickness="0"
                ZIndex="999">
            <ContentView ControlTemplate="{StaticResource ProfileInfoSkeletonTemplate}" />
        </Border>
    </Grid>

</views:BasePage>
