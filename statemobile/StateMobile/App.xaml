<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:StateMobile"
             xmlns:converters="clr-namespace:StateMobile.Converters"
             x:Class="StateMobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/SkeletonTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:InvertedBoolToTextConverter x:Key="InvertedBoolToTextConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:PasswordVisibilityIconConverter x:Key="PasswordIconConverter" />
            <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
            <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter" />
            <converters:WeatherToStatusConverter x:Key="WeatherToStatusConverter" />
            <converters:NullToBoolConverter x:Key="NullToFalseConverter" Invert="False" />
            <converters:NullToBoolConverter x:Key="NullToTrueConverter" Invert="True" />

            <ControlTemplate x:Key="MainPageTemplate">
                <Grid>
                    <Grid RowDefinitions="Auto, *">
                        <Border Grid.Row="0" 
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A2E}" 
                                StrokeThickness="0" 
                                HeightRequest="75" 
                                ZIndex="10">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1" />
                            </Border.Shadow>

                            <Grid ColumnDefinitions="Auto, *, 36, 36, 36" Padding="12,0" VerticalOptions="Center" HeightRequest="75">

                                <Frame Grid.Column="0" HeightRequest="40" WidthRequest="40" CornerRadius="20" Padding="0" IsClippedToBounds="True" BorderColor="#498789">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{TemplateBinding BindingContext.HomeCommand}"/>
                                    </Frame.GestureRecognizers>
                                    <Image Source="state_logo_only.png" Aspect="AspectFill"/>
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="10,0,5,0" Spacing="0">
                                    <Label Text="{TemplateBinding BindingContext.UserName}" 
                                           FontAttributes="Bold" 
                                           TextColor="{AppThemeBinding Light=#1A2D3E, Dark=White}" 
                                           FontSize="13.5" 
                                           Margin="0,0,0,1"/>
                                    <Label Text="{TemplateBinding BindingContext.DepartmentName}" 
                                           FontSize="9.5" 
                                           TextColor="{AppThemeBinding Light=#7F8C8D, Dark=#A0AEC0}"
                                           CharacterSpacing="0.2"/>
                                </VerticalStackLayout>

                                <Grid Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center">
                                    <ImageButton Source="chat_icon.png" 
                                                 Command="{TemplateBinding BindingContext.ChatCommand}"
                                                 BackgroundColor="Transparent" 
                                                 HeightRequest="16" 
                                                 WidthRequest="16"
                                                 Scale="0.5"/>
                                    <Frame BackgroundColor="Red" 
                                           HasShadow="False"
                                           Padding="0"
                                           HeightRequest="10"
                                           WidthRequest="10"
                                           CornerRadius="50"
                                           HorizontalOptions="End"
                                           VerticalOptions="Start"
                                           Margin="5,-5,0,0"
                                           IsVisible="{TemplateBinding BindingContext.UnreadChatCount, Converter={StaticResource CountToVisibilityConverter}}">
                                        <Label Text="{TemplateBinding BindingContext.UnreadChatCount}"
                                               TextColor="White"
                                               FontSize="8"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Frame>
                                </Grid>

                                <Grid Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center">
                                    <ImageButton Source="notification_icon.png" 
                                                 Command="{TemplateBinding BindingContext.NotificationCommand}"
                                                 BackgroundColor="Transparent" 
                                                 HeightRequest="16" 
                                                 WidthRequest="16"
                                                 Scale="0.5"/>
                                    <Frame BackgroundColor="Red" 
                                           HasShadow="False"
                                           Padding="0"
                                           HeightRequest="10"
                                           WidthRequest="10"
                                           CornerRadius="50"
                                           HorizontalOptions="End"
                                           VerticalOptions="Start"
                                           Margin="5,-5,0,0"
                                           IsVisible="{TemplateBinding BindingContext.UnreadNotificationCount, Converter={StaticResource CountToVisibilityConverter}}">
                                        <Label Text="{TemplateBinding BindingContext.UnreadNotificationCount}"
                                               TextColor="White"
                                               FontSize="8"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Frame>
                                </Grid>

                                <ImageButton Grid.Column="4" 
                                             Source="menu_hamburger.png" 
                                             Command="{TemplateBinding BindingContext.MenuCommand}"
                                             BackgroundColor="Transparent" 
                                             HeightRequest="16" 
                                             WidthRequest="16"
                                             Scale="0.5"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center"/>
                            </Grid>
                        </Border>

                        <ContentPresenter Grid.Row="1" ZIndex="0" />
                    </Grid>

                    <Border x:Name="MenuOverlay" 
                            IsVisible="False"
                            InputTransparent="False"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A2E}"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2D3748}"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Margin="0,70,15,0"
                            WidthRequest="220"
                            ZIndex="9999">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.2"/>
                        </Border.Shadow>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Padding="0" Spacing="0">
                            <Label Text="{TemplateBinding BindingContext.UserID}" HorizontalOptions="Center" FontAttributes="Bold" FontSize="18" TextColor="{AppThemeBinding Light=#34495E, Dark=White}" Padding="15"/>
                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F0, Dark=#2D3748}"/>
                            <Button Text="Account Settings" 
                                     TextColor="{AppThemeBinding Light=#555, Dark=#E2E8F0}" 
                                     BackgroundColor="Transparent" 
                                     Padding="15,12"
                                     Command="{TemplateBinding BindingContext.SettingsCommand}"/>
                            <Button Text="Logout" 
        TextColor="Red" 
        BackgroundColor="Transparent" 
        Padding="15,12"
        Command="{TemplateBinding BindingContext.LogoutCommand}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </ControlTemplate>

        </ResourceDictionary>
    </Application.Resources>
</Application>