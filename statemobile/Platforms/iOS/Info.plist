<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Other keys -->
    
    <!-- Required for Face ID -->
    <key>NSFaceIDUsageDescription</key>
    <string>We need to verify your identity using Face ID or Touch ID to access your stored credentials securely.</string>
    
    <!-- Optional: For better description -->
    <key>CFBundleDisplayName</key>
    <string>StateMobile</string>

    <!-- Allow non-HTTPS connections -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
</dict>
</plist>